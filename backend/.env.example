# ── Groq API (free tier) ──────────────────────────────────────────
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Models ────────────────────────────────────────────────────────
# Primary model for contract analysis (fast + capable)
GROQ_MODEL=llama-3.3-70b-versatile
# Fallback for lighter tasks
GROQ_MODEL_FAST=llama3-8b-8192

# ── App settings ──────────────────────────────────────────────────
APP_NAME=Legal AI Assistant
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-in-production

# ── Storage paths ─────────────────────────────────────────────────
UPLOAD_DIR=./uploads
CHROMA_DIR=./chroma_db
DATABASE_URL=sqlite+aiosqlite:///./legal_ai.db

# ── Chunking settings (tuned for legal docs) ──────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
